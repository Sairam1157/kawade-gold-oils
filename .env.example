# Strong password for /admin (required for production builds; never commit real .env)
VITE_ADMIN_PASSWORD=change-me-to-a-long-secret

# EmailJS configuration (client-side public key + service/template IDs)
# Get these values from your EmailJS dashboard and copy into a local .env file
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Example:
# VITE_EMAILJS_SERVICE_ID=service_xxx
# VITE_EMAILJS_TEMPLATE_ID=template_xxx
# VITE_EMAILJS_PUBLIC_KEY=D4-CmYtU6jCnmf6KU
